generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model gallery {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  colors      String[]
  end_date    DateTime @db.Date
  image_url   String
  opensea_url String
  title       String
}
