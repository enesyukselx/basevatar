{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "env": [
                "SESSION_SECRET",
                "DATABASE_URL",
                "ADMIN_WALLET_ADDRESS",
                "NEXTAUTH_URL",
                "LOCALSTORAGE_KEY",
                "SLACK_BOT_TOKEN",
                "UPLOAD_OUTPUT_API_KEY",
                "AWS_BUCKET_NAME",
                "AWS_REGION",
                "AWS_ACCESS_KEY_ID",
                "AWS_SECRET_ACCESS_KEY",
                "AWS_S3_URL"
            ]
        },
        "dev": {
            "dependsOn": ["^db:generate"],
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "generate": {
            "dependsOn": ["^generate"],
            "cache": false
        },
        "db:seed": {
            "dependsOn": ["^db:seed"],
            "cache": false
        },
        "typecheck": {
            "outputs": []
        },
        "lint": {
            "outputs": []
        },
        "clean": {
            "cache": false
        }
    }
}
